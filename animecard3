                  {/* Speech bubble tail */}
                  <div className="absolute -bottom-2 left-1/2 transform -translate-x-1/2 w-0 h-0 border-l-4 border-r-4 border-t-4 border-transparent border-t-white" />
                </div>
              </div>
            </div>
          </div>
          
          {/* Manga-style rating badge */}
          {displayRating && (
            <div className="absolute -top-2 -left-2 transform rotate-12">
              <div className="bg-yellow-300 text-black text-sm font-black px-4 py-2 rounded-full border-3 border-black shadow-lg flex items-center"
                style={{
                  filter: 'drop-shadow(3px 3px 0px #ff69b4)'
                }}>
                <Star className="w-4 h-4 mr-1 fill-current" />
