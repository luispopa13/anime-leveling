import React from 'react';
import { Link } from 'react-router-dom';
import { Calendar, Star, Play, Eye, Heart, Sparkles, Zap } from 'lucide-react';

const AnimeCard = ({ anime, isLatest }) => {
  const {
    id,
    title,
    image,
    rating,
    year,
