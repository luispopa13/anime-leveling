        <div className="p-5 relative bg-white border-t-4 border-black">
          {/* Background pattern */}
          <div className="absolute inset-0 opacity-5"
            style={{
              backgroundImage: `radial-gradient(circle at 25% 25%, #ff69b4 2px, transparent 2px),
                               radial-gradient(circle at 75% 75%, #00bfff 2px, transparent 2px)`,
              backgroundSize: '30px 30px'
            }}
          />
          
          {/* Title with anime text effect */}
          <div className="relative mb-4">
            <h3 className="text-black font-black text-xl mb-2 relative transform group-hover:scale-105 transition-transform duration-300"
