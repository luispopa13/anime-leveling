      <div className="absolute inset-0 opacity-0 group-hover:opacity-20 transition-opacity duration-300">
        <div className="absolute inset-0 bg-gradient-to-br from-transparent via-yellow-300/30 to-transparent transform rotate-45" />
        <div className="absolute inset-0 bg-gradient-to-tl from-transparent via-pink-300/30 to-transparent transform -rotate-45" />
