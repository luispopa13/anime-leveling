                src={imageUrl}
                alt={title}
                className="w-full h-[280px] object-cover transition-all duration-500 group-hover:scale-110 brightness-105 contrast-110 saturate-125"
                style={{
                  filter: 'drop-shadow(0 0 10px rgba(0,0,0,0.3))'
                }}
              />
              
              {/* Anime-style halftone overlay */}
              <div className="absolute inset-0 opacity-0 group-hover:opacity-30 transition-opacity duration-300"
                style={{
                  background: `radial-gradient(circle at 20% 50%, #ff69b4 2px, transparent 2px),
                               radial-gradient(circle at 80% 50%, #00bfff 2px, transparent 2px)`,
                  backgroundSize: '20px 20px'
                }}
              />
              
              {/* Speed lines effect */}
              <div className="absolute inset-0 opacity-0 group-hover:opacity-40 transition-opacity duration-300 overflow-hidden">
                <div className="absolute top-1/2 left-1/2 w-full h-0.5 bg-white transform -translate-y-1/2 -translate-x-1/2 rotate-12 shadow-lg" />
                <div className="absolute top-1/2 left-1/2 w-full h-0.5 bg-white transform -translate-y-1/2 -translate-x-1/2 -rotate-12 shadow-lg" />
                <div className="absolute top-1/2 left-1/2 w-full h-0.5 bg-white transform -translate-y-1/2 -translate-x-1/2 rotate-45 shadow-lg" />
              </div>
              
              {/* Anime sparkle effects */}
              <div className="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500">
                <Sparkles className="absolute top-4 right-4 w-6 h-6 text-yellow-400 animate-pulse" />
                <Sparkles className="absolute top-16 left-6 w-4 h-4 text-pink-400 animate-bounce" />
                <Sparkles className="absolute bottom-8 right-8 w-5 h-5 text-cyan-400 animate-ping" />
                <div className="absolute top-8 left-12 w-2 h-2 bg-white rounded-full animate-ping" />
                <div className="absolute bottom-12 left-4 w-1 h-1 bg-yellow-300 rounded-full animate-pulse" />
              </div>
              
