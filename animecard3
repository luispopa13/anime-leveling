            style={{
              filter: 'drop-shadow(2px 2px 0px #ff69b4)'
            }}>
            <div className="w-2 h-2 bg-black rounded-full" />
          </div>
        </div>
      </div>
      
      {/* Manga-style motion lines */}
      <div className="absolute -inset-4 opacity-0 group-hover:opacity-30 transition-opacity duration-300 pointer-events-none">
        <div className="absolute top-1/2 left-0 w-8 h-0.5 bg-black transform -translate-y-1/2 -rotate-12" />
        <div className="absolute top-1/2 right-0 w-8 h-0.5 bg-black transform -translate-y-1/2 rotate-12" />
        <div className="absolute top-0 left-1/2 w-0.5 h-8 bg-black transform -translate-x-1/2 rotate-12" />
        <div className="absolute bottom-0 left-1/2 w-0.5 h-8 bg-black transform -translate-x-1/2 -rotate-12" />
      </div>
    </Link>
  );
};

export default AnimeCard;