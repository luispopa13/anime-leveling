import React, { useState, useEffect } from 'react';
import { Play, Clock, Download, Server, Eye, Calendar } from 'lucide-react';
import { animeAPI } from '../services/api';

const EpisodeList = ({ animeId, onEpisodeSelect, currentEpisode = 1 }) => {
  const [episodes, setEpisodes] = useState([]);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState(null);
  const [watchProgress, setWatchProgress] = useState({});
  const [expandedEpisode, setExpandedEpisode] = useState(null);

  useEffect(() => {
    fetchEpisodes();
    fetchWatchProgress();
  }, [animeId]);

  const fetchEpisodes = async () => {
    try {
      setLoading(true);
      const data = await animeAPI.getEpisodes(animeId);
      setEpisodes(data.episodes || []);
    } catch (err) {
      setError('Failed to load episodes');
      console.error('Error fetching episodes:', err);
    } finally {
      setLoading(false);
    }
  };

  const fetchWatchProgress = async () => {
    try {
      const progress = await animeAPI.getWatchProgress(animeId);
      setWatchProgress(progress);
    } catch (err) {
      console.error('Error fetching watch progress:', err);
    }
  };

  const formatDuration = (seconds) => {
    if (!seconds) return '';
    const mins = Math.floor(seconds / 60);
    const secs = seconds % 60;
    return `${mins}:${secs.toString().padStart(2, '0')}`;
  };

  const formatDate = (dateString) => {
    if (!dateString) return '';
    return new Date(dateString).toLocaleDateString();
  };

  const getProgressPercentage = (episodeNumber) => {
    const progress = watchProgress[episodeNumber];
    if (!progress || !progress.duration) return 0;
    return Math.min((progress.watchTime / progress.duration) * 100, 100);
  };

  const isWatched = (episodeNumber) => {
    return getProgressPercentage(episodeNumber) > 90;
  };

  const handleEpisodeClick = (episode) => {
    if (onEpisodeSelect) {
      onEpisodeSelect(episode);
    }
  };

  const toggleEpisodeDetails = (episodeNumber) => {
    setExpandedEpisode(expandedEpisode === episodeNumber ? null : episodeNumber);
  };

  if (loading) {
    return (
      <div className="space-y-4">
        <div className="flex items-center justify-between">
          <h3 className="text-xl font-bold text-white">Episodes</h3>
          <div className="animate-spin rounded-full h-6 w-6 border-b-2 border-blue-500"></div>
        </div>
        <div className="space-y-2">
          {[...Array(12)].map((_, i) => (
            <div key={i} className="bg-gray-800 rounded-lg p-4 animate-pulse">
              <div className="h-4 bg-gray-700 rounded w-3/4 mb-2"></div>
              <div className="h-3 bg-gray-700 rounded w-1/2"></div>
            </div>
          ))}
        </div>
      </div>
    );
  }

  if (error) {
    return (
      <div className="bg-red-900/20 border border-red-500 rounded-lg p-4">
        <p className="text-red-400">{error}</p>
        <button 
          onClick={fetchEpisodes}
          className="mt-2 px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700 transition"
        >
          Retry
        </button>
      </div>
    );
  }

  if (episodes.length === 0) {
    return (
      <div className="bg-gray-800 rounded-lg p-6 text-center">
        <Server className="w-12 h-12 text-gray-400 mx-auto mb-4" />
        <p className="text-gray-400">No episodes available yet</p>
      </div>
    );
  }

  return (
    <div className="space-y-4">
      <div className="flex items-center justify-between">
        <h3 className="text-xl font-bold text-white">
          Episodes ({episodes.length})
        </h3>
        <div className="text-sm text-gray-400">
          {watchProgress.currentEpisode && (
            <span>Watching Episode {watchProgress.currentEpisode}</span>
          )}
        </div>
      </div>

      <div className="space-y-2 max-h-96 overflow-y-auto">
        {episodes.map((episode) => {
          const progressPercent = getProgressPercentage(episode.number);
          const watched = isWatched(episode.number);
          const isCurrent = episode.number === currentEpisode;

          return (
            <div
              key={episode.id}
              className={`bg-gray-800 rounded-lg overflow-hidden transition-all duration-200 ${
                isCurrent ? 'ring-2 ring-blue-500' : ''
              }`}
            >
              <div
                className="p-4 cursor-pointer hover:bg-gray-750 transition-colors"
                onClick={() => handleEpisodeClick(episode)}
              >
                <div className="flex items-center justify-between">
                  <div className="flex items-center space-x-3 flex-1">
                    <div className="relative">
                      <div className={`w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold ${
                        watched ? 'bg-green-600 text-white' : 
                        isCurrent ? 'bg-blue-600 text-white' : 'bg-gray-700 text-gray-300'
                      }`}>
                        {watched ? <Eye className="w-5 h-5" /> : episode.number}
                      </div>
                      {progressPercent > 0 && progressPercent < 90 && (
                        <div className="absolute -bottom-1 -right-1">
                          <div className="w-4 h-4 rounded-full bg-yellow-500 flex items-center justify-center">
                            <Clock className="w-2 h-2 text-black" />
                          </div>
                        </div>
                      )}
                    </div>

                    <div className="flex-1 min-w-0">
                      <h4 className="text-white font-medium truncate">
                        {episode.title || `Episode ${episode.number}`}
                      </h4>
                      <div className="flex items-center space-x-4 text-sm text-gray-400">
                        {episode.duration && (
                          <span className="flex items-center">
                            <Clock className="w-4 h-4 mr-1" />
                            {formatDuration(episode.duration)}
                          </span>
                        )}
                        {episode.releaseDate && (
                          <span className="flex items-center">
                            <Calendar className="w-4 h-4 mr-1" />
                            {formatDate(episode.releaseDate)}
                          </span>
                        )}
                      </div>
                    </div>
                  </div>

                  <div className="flex items-center space-x-2">
                    <button
                      onClick={(e) => {
                        e.stopPropagation();
                        toggleEpisodeDetails(episode.number);
                      }}
                      className="px-3 py-1 bg-gray-700 text-gray-300 rounded text-sm hover:bg-gray-600 transition"
                    >
                      Info
                    </button>
                    <button
                      onClick={(e) => {
                        e.stopPropagation();
                        handleEpisodeClick(episode);
                      }}
                      className="px-4 py-2 bg-blue-600 text-white rounded flex items-center space-x-2 hover:bg-blue-700 transition"
                    >
                      <Play className="w-4 h-4" />
                      <span>Watch</span>
                    </button>
                  </div>
                </div>

                {/* Progress bar */}
                {progressPercent > 0 && (
                  <div className="mt-3">
                    <div className="w-full bg-gray-700 rounded-full h-1">
                      <div
                        className={`h-1 rounded-full transition-all duration-300 ${
                          watched ? 'bg-green-500' : 'bg-blue-500'
                        }`}
                        style={{ width: `${progressPercent}%` }}
                      ></div>
                    </div>
                  </div>
                )}
              </div>

              {/* Expanded episode details */}
              {expandedEpisode === episode.number && (
                <div className="px-4 pb-4 border-t border-gray-700">
                  <div className="pt-4 space-y-2">
                    {episode.description && (
                      <p className="text-gray-300 text-sm leading-relaxed">
                        {episode.description}
                      </p>
                    )}
                    {episode.image && (
                      <img
                        src={episode.image}
                        alt={episode.title}
                        className="w-full h-40 object-cover rounded"
                      />
                    )}
                    <div className="flex items-center justify-between text-xs text-gray-400">
                      <span>Episode {episode.number}</span>
                      {episode.releaseDate && (
                        <span>Released: {formatDate(episode.releaseDate)}</span>
                      )}
                    </div>
                  </div>
                </div>
              )}
            </div>
          );
        })}
      </div>

      {/* Continue watching suggestion */}
      {watchProgress.currentEpisode && watchProgress.currentEpisode <= episodes.length && (
        <div className="bg-blue-900/20 border border-blue-500 rounded-lg p-4">
          <div className="flex items-center justify-between">
            <div>
              <h4 className="text-blue-400 font-medium">Continue Watching</h4>
              <p className="text-gray-300 text-sm">
                Episode {watchProgress.currentEpisode} - {formatDuration(watchProgress.watchTime)} watched
              </p>
            </div>
            <button
              onClick={() => {
                const episode = episodes.find(ep => ep.number === watchProgress.currentEpisode);
                if (episode) handleEpisodeClick(episode);
              }}
              className="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 transition flex items-center space-x-2"
            >
              <Play className="w-4 h-4" />
              <span>Continue</span>
            </button>
          </div>
        </div>
      )}
    </div>
  );
};

export default EpisodeList;