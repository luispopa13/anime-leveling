import React from 'react';
import { Link } from 'react-router-dom';
import { Calendar, Star, Play, Eye, Heart } from 'lucide-react';

const AnimeCard = ({ anime, isLatest }) => {
  const {
    id,
    title,
    image,
    rating,
    year,
  } = anime;

  const imageUrl = image || `http://localhost:5000/api/placeholder/300/400`;
  const displayRating = rating !== 'N/A' ? rating : null;

  return (
    <Link 
      to={`/anime/${id}`} 
      className="group relative block bg-black rounded-2xl overflow-hidden shadow-2xl hover:shadow-[0_20px_50px_rgba(139,92,246,0.3)] transition-all duration-700 transform hover:-translate-y-4 hover:rotate-1 border-2 border-purple-900/50 hover:border-pink-500/80"
    >
      {/* Background glow effect */}
      <div className="absolute -inset-1 bg-gradient-to-r from-purple-600 via-pink-600 to-red-600 rounded-2xl blur opacity-0 group-hover:opacity-75 transition duration-1000 animate-pulse" />
      
      <div className="relative bg-gradient-to-br from-gray-900 via-purple-900/20 to-black rounded-2xl">
        <div className="relative overflow-hidden rounded-t-2xl">
          <img
            src={imageUrl}
            alt={title}
            className="w-full h-[300px] object-cover transition-all duration-700 group-hover:scale-125 group-hover:brightness-110 group-hover:saturate-150"
          />
          
          {/* Multiple overlay effects */}
          <div className="absolute inset-0 bg-gradient-to-t from-black/80 via-purple-900/20 to-transparent" />
          <div className="absolute inset-0 bg-gradient-to-br from-pink-500/10 via-transparent to-blue-500/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
          
          {/* Animated shimmer streak */}
          <div className="absolute inset-0 -translate-x-full group-hover:translate-x-full transition-transform duration-1000 bg-gradient-to-r from-transparent via-white/30 to-transparent skew-x-12" />
          
          {/* Floating play button */}
          <div className="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-500 transform scale-50 group-hover:scale-100">
            <div className="bg-gradient-to-r from-pink-500 to-purple-600 rounded-full p-4 shadow-2xl animate-bounce">
              <Play className="w-8 h-8 text-white fill-current" />
            </div>
          </div>
          
          {/* Rating badge with glow */}
          {displayRating && (
            <div className="absolute top-3 left-3 bg-gradient-to-r from-yellow-400 via-orange-500 to-red-500 text-black text-xs font-black px-4 py-2 rounded-full flex items-center shadow-2xl ring-4 ring-yellow-400/50 animate-pulse">
              <Star className="w-4 h-4 mr-1 fill-current animate-spin" />
              {displayRating}
            </div>
          )}
          
          {/* Hot badge for latest */}
          {isLatest && (
            <div className="absolute top-3 right-3 bg-gradient-to-r from-red-500 via-pink-500 to-purple-600 text-white text-xs font-black px-3 py-1 rounded-full animate-bounce shadow-2xl">
              🔥 HOT
            </div>
          )}
          
          {/* Floating hearts animation */}
          <div className="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <Heart className="w-6 h-6 text-pink-400 fill-current animate-ping absolute" />
            <Heart className="w-4 h-4 text-red-400 fill-current animate-ping absolute top-8 left-8 animation-delay-200" />
            <Heart className="w-5 h-5 text-purple-400 fill-current animate-ping absolute -top-6 -left-4 animation-delay-500" />
          </div>
        </div>
        
        <div className="p-4 relative">
          {/* Animated background particles */}
          <div className="absolute inset-0 opacity-20">
            <div className="absolute top-2 left-4 w-1 h-1 bg-purple-400 rounded-full animate-ping" />
            <div className="absolute top-6 right-8 w-1 h-1 bg-pink-400 rounded-full animate-ping animation-delay-300" />
            <div className="absolute bottom-4 left-12 w-1 h-1 bg-blue-400 rounded-full animate-ping animation-delay-700" />
          </div>
          
          <h3 className="text-white font-black text-lg mb-2 relative overflow-hidden group-hover:text-transparent group-hover:bg-gradient-to-r group-hover:from-purple-400 group-hover:via-pink-400 group-hover:to-red-400 group-hover:bg-clip-text transition-all duration-500 transform group-hover:scale-105">
            {title}
            {/* Text glow effect */}
            <span className="absolute inset-0 text-purple-400 opacity-0 group-hover:opacity-50 blur-sm transition-opacity duration-500">{title}</span>
          </h3>
          
          <div className="flex items-center justify-between">
            <div className="flex items-center text-gray-300 text-sm group-hover:text-white transition-colors duration-300">
              <Calendar className="w-4 h-4 mr-2 text-purple-400 group-hover:text-pink-400 transition-colors duration-300 group-hover:animate-pulse" />
              <span className="font-bold">{year || 'Unknown'}</span>
            </div>
            
            {/* Watch counter with animation */}
            <div className="flex items-center text-purple-400 text-xs font-bold opacity-0 group-hover:opacity-100 transition-all duration-500 transform translate-x-4 group-hover:translate-x-0">
              <Eye className="w-4 h-4 mr-1 animate-pulse" />
              <span className="animate-pulse">WATCH NOW</span>
            </div>
          </div>
          
          {/* Animated progress bar */}
          <div className="mt-3 h-1 bg-gray-800 rounded-full overflow-hidden">
            <div className="h-full bg-gradient-to-r from-purple-500 via-pink-500 to-red-500 rounded-full transform -translate-x-full group-hover:translate-x-0 transition-transform duration-1000 ease-out" />
          </div>
        </div>
        
        {/* Corner accent */}
        <div className="absolute top-0 right-0 w-16 h-16 bg-gradient-to-bl from-pink-500/20 to-transparent rounded-tr-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
      </div>
    </Link>
  );
};

export default AnimeCard;